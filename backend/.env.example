# Copy to backend/.env and adjust. See docs/adr/0001-foundation-auth.md.

# Signs sessions + Fernet-encrypts provider keys at rest. BACK THIS UP:
# losing/changing it invalidates stored provider keys and all sessions (S10).
PUTTYU_SECRET_KEY=change-me-to-a-long-random-string

PUTTYU_DATA_DIR=data
PUTTYU_LIBRARY_PATH=../textbooks
# PUTTYU_DB_URL=sqlite:///data/app.db   # default derived from DATA_DIR
PUTTYU_HOST=127.0.0.1
PUTTYU_PORT=7000

# 1 = use the deterministic FakeProvider for tests (no real model / tokens).
PUTTYU_TEST_MODE=0
PUTTYU_EMBED_MODEL=BAAI/bge-small-en-v1.5
