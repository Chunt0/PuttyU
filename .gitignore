# PuttyU .gitignore — project-owned (the inherited one is gone; keep this lean).

# Local-only knowledge bases & content — mined during the build, never shipped
/ODYSSEUS-REF/
/OLD-REF/
/putty-ai-design/
/resources/
/textbooks/
/example-textbook/

# Python
__pycache__/
*.py[co]
.venv/
.pytest_cache/

# Env & secrets (committed example documents every variable)
.env
!.env.example

# Runtime data — user data stays local (SQLite + WAL, Chroma, uploads, logs)
data/
*.db
*.sqlite3
*.log

# Web toolchain
node_modules/
dist/

# Playwright e2e artifacts (Gate 3b)
test-results/
playwright-report/

# Agent / editor / OS
.claude/
.vscode/
.idea/
*.swp
.DS_Store
